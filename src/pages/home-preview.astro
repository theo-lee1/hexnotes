---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { countBy, formatDate, slugify, sortPosts } from '../lib/content';

const posts = sortPosts(await getCollection('blog'));
const [featured, second, third, ...rest] = posts;
const latest = rest.slice(0, 4);
const categories = countBy(posts, (post) => post.data.category).slice(0, 5);
const tags = countBy(posts, (post) => post.data.tags).slice(0, 10);
---

<BaseLayout title={`首页预览 | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<div class="front-lab">
		<section class="front-identity">
			<p>Hex Notes</p>
			<h1>{SITE_TITLE}</h1>
			<span>{SITE_DESCRIPTION}</span>
		</section>

		<section class="front-board" aria-label="精选文章">
			{
				featured && (
					<a class="front-lead" href={`/blog/${featured.id}/`}>
						<div class="front-meta">
							<span>{featured.data.category}</span>
							<time datetime={featured.data.pubDate.toISOString()}>{formatDate(featured.data.pubDate)}</time>
						</div>
						<h2>{featured.data.title}</h2>
						<p>{featured.data.description}</p>
						<strong>阅读文章 <span aria-hidden="true">→</span></strong>
					</a>
				)
			}
			<div class="front-stack">
				{second && (
					<a class="front-stack-card" href={`/blog/${second.id}/`}>
						<span>01</span>
						<strong>{second.data.title}</strong>
						<small>{second.data.category} · {formatDate(second.data.pubDate)}</small>
					</a>
				)}
				{third && (
					<a class="front-stack-card" href={`/blog/${third.id}/`}>
						<span>02</span>
						<strong>{third.data.title}</strong>
						<small>{third.data.category} · {formatDate(third.data.pubDate)}</small>
					</a>
				)}
				<a class="front-stack-link" href="/blog">进入全部文章 <span aria-hidden="true">→</span></a>
			</div>
		</section>

		<section class="front-catalog" aria-label="站内索引">
			<div class="front-catalog-block front-catalog-wide">
				<div class="front-section-head">
					<h2>最新文章</h2>
					<a href="/blog">全部 <span aria-hidden="true">→</span></a>
				</div>
				<div class="front-feed">
					{latest.map((post) => <ArticleCard post={post} />)}
				</div>
			</div>

			<aside class="front-catalog-block">
				<div class="front-section-head">
					<h2>分类</h2>
					<a href="/categories">全部 <span aria-hidden="true">→</span></a>
				</div>
				<div class="front-topic-list">
					{
						categories.map(([category, count], index) => (
							<a href={`/categories/${slugify(category)}/`}>
								<span>{String(index + 1).padStart(2, '0')}</span>
								<strong>{category}</strong>
								<small>{count} 篇</small>
							</a>
						))
					}
				</div>
			</aside>

			<aside class="front-catalog-block">
				<div class="front-section-head">
					<h2>标签</h2>
					<a href="/tags">全部 <span aria-hidden="true">→</span></a>
				</div>
				<div class="front-tag-list">
					{
						tags.map(([tag, count]) => (
							<a href={`/tags/${slugify(tag)}/`}>
								<span>#</span>{tag}<small>{count}</small>
							</a>
						))
					}
				</div>
			</aside>
		</section>
	</div>
</BaseLayout>

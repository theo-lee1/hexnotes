---
import { getCollection } from 'astro:content';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCategoryColor, slugify, sortPosts } from '../lib/content';

const posts = sortPosts(await getCollection('blog', ({ data }) => !data.draft));
const POSTS_PER_PAGE = 10;

const postsData = posts.map(p => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  category: p.data.category,
  categorySlug: slugify(p.data.category),
  tags: p.data.tags.map((tag) => ({ name: tag, slug: slugify(tag) })),
  pubDate: p.data.pubDate,
  categoryColor: getCategoryColor(p.data.category),
}));
const postsJson = JSON.stringify(postsData);
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<BaseLayout title="搜索 | Hex Notes" description="搜索文章、分类和标签。">
	<PageHero title="搜索" description="搜索文章、分类和标签。" />
	<section class="search-lab">
		<p class="search-summary" id="search-summary">输入关键词后查看匹配结果。</p>
		<div class="search-result-list" id="search-results"></div>
		<div class="pagination-wrapper" id="pagination"></div>
	</section>
</BaseLayout>

<script is:inline define:vars={{ postsJson, POSTS_PER_PAGE, baseUrl }}>
// @ts-nocheck
const allPosts = JSON.parse(postsJson);
const searchSummary = document.getElementById('search-summary');
const searchResults = document.getElementById('search-results');
const paginationEl = document.getElementById('pagination');
const searchLab = document.querySelector('.search-lab');

function scrollToResults() {
  searchLab?.scrollIntoView({ block: 'start', behavior: 'smooth' });
}

function searchPosts(query, posts) {
  if (!query.trim()) return [];
  const keyword = query.trim().toLowerCase();
  return posts.filter(post =>
    post.title.toLowerCase().includes(keyword) ||
    post.description.toLowerCase().includes(keyword) ||
    post.category.toLowerCase().includes(keyword) ||
    post.tags.some(t => t.name.toLowerCase().includes(keyword))
  );
}

function escapeHtml(value) {
  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function escapeAttr(value) {
  return escapeHtml(value).replace(/`/g, '&#96;');
}

function getPages(current, total) {
  if (total <= 5) return Array.from({ length: total }, (_, i) => i + 1);
  if (current <= 4) {
    const pages = [1, 2, 3, 4, 5];
    if (total > 6) pages.push('...');
    pages.push(total);
    return pages;
  }
  if (current >= total - 3) {
    const pages = [1];
    if (total > 6) pages.push('...');
    for (let i = total - 4; i <= total; i++) pages.push(i);
    return pages;
  }
  return [1, '...', current - 1, current, current + 1, '...', total];
}

function renderPagination(query, page, total) {
  if (total <= 1) return '';
  const pages = getPages(page, total);
  const prevDisabled = page <= 1 ? 'is-disabled' : '';
  const nextDisabled = page >= total ? 'is-disabled' : '';
  // 检测移动端
  const isMobile = window.innerWidth <= 720;
  const prevText = isMobile ? '◀' : '上一页';
  const nextText = isMobile ? '▶' : '下一页';
  return `
    <nav class="pagination" aria-label="分页导航">
      <span class="pagination-summary">第 ${page} / ${total} 页，共 ${total} 页</span>
      <div class="pagination-links">
        <button type="button" class="pagination-step ${prevDisabled}" data-page="${page - 1}" data-query="${encodeURIComponent(query)}">${prevText}</button>
        ${pages.map(p => p === '...'
          ? '<span class="is-ellipsis" aria-hidden="true">...</span>'
          : `<button type="button" class="pagination-page ${p === page ? 'is-active' : ''}" data-page="${p}" data-query="${encodeURIComponent(query)}">${p}</button>`
        ).join('')}
        <button type="button" class="pagination-step ${nextDisabled}" data-page="${page + 1}" data-query="${encodeURIComponent(query)}">${nextText}</button>
      </div>
    </nav>
  `;
}

function formatDate(dateStr) {
  return new Date(dateStr).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

function render(query, page = 1) {
  const filtered = searchPosts(query, allPosts);
  const totalPages = Math.max(1, Math.ceil(filtered.length / POSTS_PER_PAGE));
  const safePage = Math.min(Math.max(1, page), totalPages);
  const start = (safePage - 1) * POSTS_PER_PAGE;
  const paginated = filtered.slice(start, start + POSTS_PER_PAGE);

  if (!query.trim()) {
    searchSummary.textContent = '输入关键词后查看匹配结果。';
    searchResults.innerHTML = '';
    paginationEl.innerHTML = '';
    return;
  }

  searchSummary.innerHTML = `找到 <strong>${filtered.length}</strong> 条与 "<strong>${escapeHtml(query.trim())}</strong>" 相关的内容。`;

  if (paginated.length === 0) {
    searchResults.innerHTML = '<p class="no-results">没有找到匹配的内容。</p>';
    paginationEl.innerHTML = '';
    return;
  }

  searchResults.innerHTML = paginated.map(post => {
    const accent = post.categoryColor;
    const r = parseInt(accent.slice(1, 3), 16);
    const g = parseInt(accent.slice(3, 5), 16);
    const b = parseInt(accent.slice(5, 7), 16);
    const accentRgb = `${r}, ${g}, ${b}`;
    const href = `${baseUrl}/blog/${encodeURIComponent(post.id)}/`;
    const date = formatDate(post.pubDate);
    const safeTitle = escapeHtml(post.title);
    const safeDescription = escapeHtml(post.description);
    const safeCategory = escapeHtml(post.category);
    const safeCategorySlug = escapeAttr(post.categorySlug);

    return `
    <article class="note-card article-card-concept article-card-concept-index-slab" style="--note-accent: ${accent}; --note-accent-rgb: ${accentRgb}">
      <div class="article-card-concept-body note-card-body">
        <p class="article-card-concept-meta note-card-meta">
          <a href="${baseUrl}/categories/${safeCategorySlug}/" class="note-card-category">${safeCategory}</a>
          <time datetime="${escapeAttr(post.pubDate)}">${date}</time>
        </p>
        <h3>
          <a href="${href}" class="note-card-title">${safeTitle}</a>
        </h3>
        <p>${safeDescription}</p>
      </div>
      <div class="article-card-concept-bottom note-card-bottom">
        <div class="topic-chips">
          ${post.tags.map(tag => `
            <a href="${baseUrl}/tags/${escapeAttr(tag.slug)}/" class="topic-chip">
              <span class="topic-chip-prefix" aria-hidden="true">#</span>
              <span>${escapeHtml(tag.name)}</span>
            </a>
          `).join('')}
        </div>
        <a href="${href}" class="read-link" aria-label="阅读 ${escapeAttr(post.title)}">
          阅读
          <svg aria-hidden="true" viewBox="0 0 24 24" width="15" height="15">
            <path d="M7 17 17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </article>
    `;
  }).join('');

  paginationEl.innerHTML = renderPagination(query, safePage, totalPages);

  paginationEl.querySelectorAll('button.pagination-step:not(.is-disabled)').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = parseInt(btn.dataset.page);
      const q = decodeURIComponent(btn.dataset.query);
      render(q, p);
      scrollToResults();
    });
  });

  paginationEl.querySelectorAll('button.pagination-page').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = parseInt(btn.dataset.page);
      const q = decodeURIComponent(btn.dataset.query);
      render(q, p);
      scrollToResults();
    });
  });
}

// 初始化：尝试从 URL 读取搜索词
const urlParams = new URLSearchParams(window.location.search);
const initialQuery = urlParams.get('q') || '';
if (initialQuery) {
  render(initialQuery, 1);
}

window.addEventListener('hexnotes:search-query-change', (event) => {
  render(event.detail?.q || '', 1);
});

window.addEventListener('popstate', () => {
  const params = new URLSearchParams(window.location.search);
  render(params.get('q') || '', 1);
});
</script>

<style>
.search-summary {
  margin-bottom: 24px;
  color: var(--ink-soft);
}

.search-summary strong {
  color: var(--ink);
}

.search-result-list {
  display: grid;
  gap: 16px;
}

.pagination-wrapper {
  margin-top: 32px;
}

.no-results {
  text-align: center;
  padding: 48px 0;
  color: var(--ink-soft);
}

.pagination {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  border: 1px solid var(--surface-frame-border);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.028), rgba(255, 255, 255, 0.012)), rgba(255, 255, 255, 0.014);
  padding: 14px 16px;
}

.pagination-summary {
  color: var(--ink-soft);
  font-family: var(--font-geist-mono), monospace;
  font-size: 0.72rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.pagination-links {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
}

.pagination-links a,
.pagination-links button {
  display: inline-flex;
  min-width: 38px;
  min-height: 36px;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--surface-frame-border);
  background: rgba(255, 255, 255, 0.024);
  padding: 8px 11px;
  color: var(--ink-soft);
  cursor: pointer;
  font-size: 0.86rem;
  font-family: var(--font-geist-mono), monospace;
  text-decoration: none;
  transition: all 0.2s;
}

.pagination-links a:hover {
	border-color: rgba(124, 183, 255, 0.28);
	background: rgba(124, 183, 255, 0.08);
	color: var(--ink);
}

.pagination-links button:hover {
	border-color: rgba(124, 183, 255, 0.28);
	background: rgba(124, 183, 255, 0.08);
	color: var(--ink);
}

.is-ellipsis {
  display: inline-flex;
  min-width: 38px;
  min-height: 36px;
  align-items: center;
  justify-content: center;
  color: var(--ink-soft);
  font-size: 0.86rem;
  user-select: none;
}

.pagination-page {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  padding: 0 !important;
}

.pagination-step {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 38px;
  min-width: 64px;
  padding-inline: 12px;
  border: 1px solid var(--surface-frame-border);
  font-size: 0.86rem;
  font-family: var(--font-geist-mono), monospace;
}

.is-disabled {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 38px;
  min-width: 64px;
  padding-inline: 12px;
  border: 1px solid var(--surface-frame-border);
  font-size: 0.86rem;
  font-family: var(--font-geist-mono), monospace;
  opacity: 0.4;
  cursor: not-allowed;
}

.is-active {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border: 1px solid var(--cyan);
  background: rgba(94, 231, 255, 0.12);
  color: var(--cyan);
  font-size: 0.86rem;
  font-family: var(--font-geist-mono), monospace;
}

@media (max-width: 720px) {
  .pagination {
    flex-direction: column;
    gap: 12px;
    padding: 12px;
  }

  .pagination-links {
    justify-content: center;
    gap: 4px;
  }

  .pagination-summary {
    text-align: center;
  }

  .pagination-links a,
  .pagination-links button,
  .pagination-step,
  .is-disabled,
  .pagination-page,
  .is-active,
  .is-ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: unset;
    min-width: unset;
    height: 28px;
    font-size: 0.75rem;
  }

  .pagination-links a,
  .pagination-links button {
    min-width: 28px;
    padding: 0;
  }

  .pagination-step {
    min-width: 32px;
    padding-inline: 0;
    border: 1px solid var(--surface-frame-border);
  }

  .is-disabled {
    min-width: 32px;
    padding-inline: 0;
    border: 1px solid var(--surface-frame-border);
    opacity: 0.4;
  }

  .is-active,
  .pagination-page {
    width: 28px;
    min-width: 28px;
    padding: 0;
  }

  .is-ellipsis {
    min-width: 28px;
  }
}
</style>

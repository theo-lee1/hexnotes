---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { countBy, formatDate, slugify, sortPosts } from '../lib/content';

const posts = sortPosts(await getCollection('blog'));
const [featured, ...rest] = posts;
const latest = rest.slice(0, 6);
const categories = countBy(posts, (post) => post.data.category);
const totalArticles = posts.length;
const totalCategories = categories.length;
const totalTags = [...new Set(posts.flatMap((p) => p.data.tags))].length;
---

<BaseLayout title={`监控面板 | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<div class="monitor-lab">
		<!-- 顶部状态栏 -->
		<header class="monitor-header">
			<div class="monitor-logo">
				<span class="monitor-dot"></span>
				<div class="monitor-title-group">
					<strong>{SITE_TITLE}</strong>
					<span class="monitor-subtitle">{SITE_TAGLINE}</span>
				</div>
			</div>
			<div class="monitor-status">
				<span class="status-indicator"></span>
				<span>AI 系统在线</span>
				<time>{new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit', second: '2-digit' })}</time>
			</div>
		</header>

		<!-- 数据面板 -->
		<section class="monitor-stats">
			<div class="stat-card">
				<div class="stat-label">文章</div>
				<div class="stat-value">{totalArticles}</div>
				<div class="stat-bar"><span style="width: 85%"></span></div>
			</div>
			<div class="stat-card">
				<div class="stat-label">分类</div>
				<div class="stat-value">{totalCategories}</div>
				<div class="stat-bar"><span style="width: 100%"></span></div>
			</div>
			<div class="stat-card">
				<div class="stat-label">标签</div>
				<div class="stat-value">{totalTags}</div>
				<div class="stat-bar"><span style="width: 60%"></span></div>
			</div>
			<div class="stat-card stat-card-accent">
				<div class="stat-label">系统</div>
				<div class="stat-value">运行中</div>
				<div class="stat-indicator">24/7</div>
			</div>
		</section>

		<!-- 精选文章 -->
		<section class="monitor-featured">
			<div class="monitor-section-header">
				<span class="monitor-tag">// 最新</span>
			</div>
			<a href={`/blog/${featured.id}/`} class="featured-panel">
				<div class="featured-meta">
					<span class="featured-category">{featured.data.category}</span>
					<time>{formatDate(featured.data.pubDate)}</time>
					<span class="featured-words">{featured.body.length} 字</span>
				</div>
				<h3>{featured.data.title}</h3>
				<p>{featured.data.description}</p>
				<div class="featured-action">
					<span>阅读全文</span>
					<svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
						<path d="M7 17 17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</div>
			</a>
		</section>

		<!-- 底部布局 -->
		<section class="monitor-bottom">
			<!-- 最近文章 -->
			<div class="monitor-recent">
				<div class="monitor-section-header">
					<span class="monitor-tag">// 最近</span>
				</div>
				<div class="recent-grid">
					{latest.slice(0, 4).map((post, i) => (
						<a href={`/blog/${post.id}/`} class="recent-card">
							<div class="recent-card-num">0{i + 1}</div>
							<div class="recent-card-body">
								<span class="recent-card-cat">{post.data.category}</span>
								<strong>{post.data.title}</strong>
								<time>{formatDate(post.data.pubDate)}</time>
							</div>
							<div class="recent-card-arrow">→</div>
						</a>
					))}
				</div>
				<a href="/blog" class="monitor-link">查看全部 →</a>
			</div>

			<!-- 分类列表 -->
			<div class="monitor-categories">
				<div class="monitor-section-header">
					<span class="monitor-tag">// 分类</span>
				</div>
				<div class="cat-grid">
					{categories.slice(0, 6).map(([cat, count], i) => (
						<a href={`/categories/${slugify(cat)}/`} class="cat-card" style={`--cat-index: ${i}`}>
							<span class="cat-card-num">0{i + 1}</span>
							<div class="cat-card-info">
								<span class="cat-card-name">{cat}</span>
								<span class="cat-card-count">{count} 篇</span>
							</div>
						</a>
					))}
				</div>
				<a href="/categories" class="monitor-link">全部分类 →</a>
			</div>
		</section>

		<!-- 页脚 -->
		<footer class="monitor-footer">
			<span>AI 驱动</span>
			<span>·</span>
			<span>{SITE_TITLE}</span>
			<span>·</span>
			<span>{new Date().getFullYear()}</span>
		</footer>
	</div>

	<script>
		// 实时时钟
		setInterval(() => {
			const timeEl = document.querySelector('.monitor-status time');
			if (timeEl) {
				timeEl.textContent = new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
			}
		}, 1000);
	</script>
</BaseLayout>

<style>
.monitor-lab {
		display: grid;
		gap: 20px;
		padding: 24px;
		max-width: 1400px;
		margin: 0 auto;
		animation: pageReveal 0.4s ease both;
	}

	.monitor-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 16px 24px;
		border: 1px solid var(--surface-frame-border);
		background: var(--surface-frame-bg);
	}

	.monitor-logo {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.monitor-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--cyan);
		box-shadow: 0 0 8px var(--cyan);
		animation: pulse 2s ease infinite;
	}

	.monitor-title-group {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.monitor-logo strong {
		font-family: var(--font-display);
		font-size: 1.8rem;
		font-weight: 500;
		color: var(--ink);
		line-height: 1;
	}

	.monitor-subtitle {
		font-size: 0.8rem;
		color: var(--ink-soft);
	}

	.monitor-version {
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.7rem;
		color: var(--ink-soft);
		padding: 2px 8px;
		border: 1px solid var(--line);
	}

	.monitor-status {
		display: flex;
		align-items: center;
		gap: 12px;
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.75rem;
		color: var(--cyan);
		letter-spacing: 0.1em;
	}

	.status-indicator {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--green);
		box-shadow: 0 0 6px var(--green);
		animation: pulse 1.5s ease infinite;
	}

	.monitor-stats {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 16px;
	}

	.stat-card {
		padding: 20px 24px;
		border: 1px solid var(--surface-frame-border);
		background: var(--surface-frame-bg);
	}

	.stat-card-accent {
		border-color: var(--cyan);
		background: linear-gradient(135deg, rgba(94, 231, 255, 0.05), transparent);
	}

	.stat-label {
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.65rem;
		letter-spacing: 0.15em;
		color: var(--ink-soft);
		margin-bottom: 8px;
	}

	.stat-value {
		font-family: var(--font-display);
		font-size: 2.8rem;
		font-weight: 500;
		color: var(--ink);
		line-height: 1;
	}

	.stat-bar {
		margin-top: 12px;
		height: 3px;
		background: var(--line);
		border-radius: 2px;
		overflow: hidden;
	}

	.stat-bar span {
		display: block;
		height: 100%;
		background: linear-gradient(90deg, var(--cyan), var(--blue));
	}

	.stat-indicator {
		margin-top: 8px;
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.7rem;
		color: var(--green);
	}

	.monitor-section-header {
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 12px 0;
		border-bottom: 1px solid var(--line);
		margin-bottom: 16px;
	}

	.monitor-tag {
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.7rem;
		color: var(--cyan);
		letter-spacing: 0.1em;
	}

	.monitor-featured {
		padding: 24px;
		border: 1px solid var(--surface-frame-border);
		background: var(--surface-frame-bg);
	}

	.featured-panel {
		display: block;
		padding: 24px;
		margin-top: 16px;
		border: 1px solid var(--line);
		background: rgba(255,255,255,0.02);
		transition: all 0.2s ease;
	}

	.featured-panel:hover {
		border-color: var(--cyan);
		background: rgba(94, 231, 255, 0.03);
	}

	.featured-meta {
		display: flex;
		gap: 16px;
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.7rem;
		color: var(--ink-soft);
		margin-bottom: 12px;
	}

	.featured-category {
		color: var(--blue);
	}

	.featured-panel h3 {
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 3vw, 2.8rem);
		font-weight: 500;
		color: var(--ink);
		margin: 0 0 12px;
		line-height: 1.2;
	}

	.featured-panel p {
		color: var(--ink-soft);
		font-size: 1rem;
		line-height: 1.6;
		margin: 0 0 20px;
	}

	.featured-action {
		display: flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.75rem;
		color: var(--cyan);
		letter-spacing: 0.1em;
	}

	.monitor-bottom {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 20px;
	}

	.monitor-recent,
	.monitor-categories {
		padding: 20px 24px;
		border: 1px solid var(--surface-frame-border);
		background: var(--surface-frame-bg);
	}

	.recent-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.recent-card {
		display: grid;
		grid-template-columns: 36px 1fr auto;
		gap: 14px;
		align-items: center;
		padding: 16px;
		border: 1px solid var(--line);
		background: rgba(255,255,255,0.02);
		transition: all 0.2s ease;
	}

	.recent-card:hover {
		border-color: var(--cyan);
		background: rgba(94, 231, 255, 0.03);
	}

	.recent-card:hover .recent-card-num {
		color: var(--cyan);
	}

	.recent-card:hover .recent-card-arrow {
		transform: translate(3px, -3px);
		color: var(--cyan);
	}

	.recent-card-num {
		font-family: var(--font-display);
		font-size: 1.8rem;
		font-weight: 300;
		color: var(--line);
		line-height: 1;
		transition: color 0.2s;
	}

	.recent-card-body {
		display: grid;
		gap: 6px;
		min-width: 0;
	}

	.recent-card-cat {
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.62rem;
		color: var(--blue);
		letter-spacing: 0.05em;
	}

	.recent-card-body strong {
		font-family: var(--font-display);
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--ink);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.recent-card-body time {
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.6rem;
		color: var(--ink-soft);
	}

	.recent-card-arrow {
		font-family: var(--font-geist-mono), monospace;
		font-size: 1rem;
		color: var(--ink-soft);
		transition: all 0.2s;
	}

	.category-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.category-chip {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 8px 14px;
		border: 1px solid var(--line);
		font-size: 0.85rem;
		color: var(--ink);
		transition: all 0.2s ease;
	}

	.category-chip:hover {
		border-color: var(--blue);
		background: rgba(124, 183, 255, 0.08);
	}

	.cat-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 10px;
	}

	.cat-card {
		display: grid;
		grid-template-columns: 32px 1fr;
		gap: 12px;
		align-items: center;
		padding: 14px;
		border: 1px solid var(--line);
		background: rgba(255,255,255,0.02);
		transition: all 0.2s ease;
	}

	.cat-card:hover {
		border-color: var(--blue);
		background: rgba(124, 183, 255, 0.05);
	}

	.cat-card:hover .cat-card-num {
		color: var(--blue);
	}

	.cat-card-num {
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.75rem;
		color: var(--line);
		transition: color 0.2s;
	}

	.cat-card-info {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.cat-card-name {
		font-size: 0.9rem;
		color: var(--ink);
	}

	.cat-card-count {
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.6rem;
		color: var(--ink-soft);
	}

	.monitor-link {
		display: inline-block;
		margin-top: 16px;
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.75rem;
		color: var(--blue);
		letter-spacing: 0.08em;
	}

	.monitor-footer {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 12px;
		padding: 24px;
		font-family: var(--font-geist-mono), monospace;
		font-size: 0.7rem;
		color: var(--ink-soft);
		letter-spacing: 0.1em;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.5; }
	}
</style>
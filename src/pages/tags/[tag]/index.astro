---
import { getCollection } from 'astro:content';
import ArticleCard from '../../../components/ArticleCard.astro';
import PageHero from '../../../components/PageHero.astro';
import Pagination from '../../../components/Pagination.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { slugify, sortPosts } from '../../../lib/content';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog', ({ data }) => !data.draft);
	const tags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

	return tags.flatMap((tag) => {
		const posts = sortPosts(allPosts.filter((post) => post.data.tags.includes(tag)));
		const totalPages = Math.ceil(posts.length / 10);
		return [{
			params: { tag: slugify(tag) },
			props: { tag, posts: posts.slice(0, 10), currentPage: 1, totalPages },
		}];
	});
}

const { tag, posts, currentPage, totalPages } = Astro.props;
---

<BaseLayout title={`${tag} | Hex Notes`} description={`包含 ${tag} 标签的文章。`}>
	<PageHero title={tag} description={`包含 ${tag} 标签的文章。`} />
	<div class="note-feed">
		{posts.map((post) => <ArticleCard post={post} />)}
	</div>
	{totalPages > 1 && (
		<div class="pagination-wrapper">
			<Pagination currentPage={currentPage} totalPages={totalPages} baseUrl={`/tags/${slugify(tag)}`} />
		</div>
	)}
</BaseLayout>

<style>
	.pagination-wrapper {
		margin-top: 32px;
	}
</style>

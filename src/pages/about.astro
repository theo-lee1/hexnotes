---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entry = await getEntry('pages', 'about');
if (!entry) {
	throw new Error('Missing about page content: src/content/pages/about.md');
}
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | Hex Notes`} description={entry.data.description}>
	<article class="reading-page">
		<header class="reading-header">
			<h1>{entry.data.title}</h1>
			<p>{entry.data.description}</p>
		</header>
		<div class="reading-layout">
			<div class="reading-surface">
				<div class="prose markdown-content markdown-body">
					<Content />
				</div>
			</div>
		</div>
	</article>
</BaseLayout>

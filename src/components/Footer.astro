---
import { CONTACT_EMAIL, CONTACT_GITHUB, CONTACT_GITEE, CONTACT_QQ, SITE_TITLE, SITE_TAGLINE } from '../consts';
import { withBase } from '../lib/urls';
---

<footer class="site-footer">
	<div class="site-footer-brand">
		<strong>{SITE_TITLE}</strong>
		<p>{SITE_TAGLINE}</p>
	</div>
	<div class="site-footer-side">
		<nav class="site-footer-nav" aria-label="页脚导航">
			<a href={withBase('/blog')}>文章</a>
			<a href={withBase('/categories')}>分类</a>
			<a href={withBase('/archive')}>归档</a>
			<a href={withBase('/about')}>关于</a>
		</nav>
		<div class="site-footer-contact">
			<div class="site-footer-contact-links">
				<a class="site-footer-contact-link" href={`mailto:${CONTACT_EMAIL}`} aria-label="邮箱" title="邮箱">
					<svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
						<path d="M4 6h16v12H4z" fill="none" stroke="currentColor" stroke-width="1.8" />
						<path d="m4.5 7 7.5 6 7.5-6" fill="none" stroke="currentColor" stroke-width="1.8" />
					</svg>
				</a>
				{CONTACT_QQ && (
					<a class="site-footer-contact-link" href={`http://wpa.qq.com/msgrd?v=3&uin=${CONTACT_QQ}&site=qq&menu=yes`} target="_blank" rel="noreferrer" aria-label="QQ" title={`QQ: ${CONTACT_QQ}`}>
						<svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
							<path d="M21.395 15.035a40 40 0 0 0-.803-2.264l-1.079-2.695c.001-.032.014-.562.014-.836C19.526 4.632 17.351 0 12 0S4.474 4.632 4.474 9.241c0 .274.013.804.014.836l-1.08 2.695a39 39 0 0 0-.802 2.264c-1.021 3.283-.69 4.643-.438 4.673.54.065 2.103-2.472 2.103-2.472 0 1.469.756 3.387 2.394 4.771-.612.188-1.363.479-1.845.835-.434.32-.379.646-.301.778.343.578 5.883.369 7.482.189 1.6.18 7.14.389 7.483-.189.078-.132.132-.458-.301-.778-.483-.356-1.233-.646-1.846-.836 1.637-1.384 2.393-3.302 2.393-4.771 0 0 1.563 2.537 2.103 2.472.251-.03.581-1.39-.438-4.673" fill="currentColor"/>
						</svg>
					</a>
				)}
				{CONTACT_GITHUB && (
					<a class="site-footer-contact-link" href={CONTACT_GITHUB} target="_blank" rel="noreferrer" aria-label="GitHub" title="GitHub">
						<svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
							<path d="M12 2.7a9.4 9.4 0 0 0-3 18.3c.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 .1 1.6 1 1.6 1 .9 1.5 2.3 1.1 2.9.8.1-.6.3-1.1.6-1.3-2.3-.3-4.8-1.2-4.8-5.2 0-1.1.4-2.1 1-2.8-.1-.3-.4-1.4.1-2.8 0 0 .9-.3 2.9 1.1a9.8 9.8 0 0 1 5.2 0c2-1.4 2.9-1.1 2.9-1.1.5 1.4.2 2.5.1 2.8.7.7 1 1.7 1 2.8 0 4-2.4 4.9-4.8 5.2.4.3.7 1 .7 2v2.5c0 .3.2.6.7.5A9.4 9.4 0 0 0 12 2.7Z" fill="currentColor" />
						</svg>
					</a>
				)}
				{CONTACT_GITEE && (
					<a class="site-footer-contact-link" href={CONTACT_GITEE} target="_blank" rel="noreferrer" aria-label="Gitee" title="Gitee">
						<svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
							<path d="M11.984 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.016 0zm6.09 5.333c.328 0 .593.266.592.593v1.482a.594.594 0 0 1-.593.592H9.777c-.982 0-1.778.796-1.778 1.778v5.63c0 .327.266.592.593.592h5.63c.982 0 1.778-.796 1.778-1.778v-.296a.593.593 0 0 0-.592-.593h-4.15a.592.592 0 0 1-.592-.592v-1.482a.593.593 0 0 1 .593-.592h6.815c.327 0 .593.265.593.592v3.408a4 4 0 0 1-4 4H5.926a.593.593 0 0 1-.593-.593V9.778a4.444 4.444 0 0 1 4.445-4.444h8.296Z" fill="currentColor"/>
						</svg>
					</a>
				)}
			</div>
		</div>
	</div>
</footer>
